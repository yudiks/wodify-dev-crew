# LLM provider for the CrewAI agents' own reasoning (pick one).
# This is separate from Claude Code's own login/credentials — Claude Code is
# invoked as a subprocess via the `claude` CLI, using whatever account you're
# already logged into on this machine.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Absolute or relative (to agents/) path to the wodify-clone app that the
# Claude Code sub-agents will operate on.
WODIFY_CLONE_DIR=../web
